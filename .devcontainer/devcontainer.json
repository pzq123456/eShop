{
    "name": "Custom NVIDIA CUDA Dev Container",
    "build": {
        "dockerfile": "Dockerfile"
    },
    // 关键：将 GPU 映射进容器
    "runArgs": [
        "--gpus", "all",
        "--shm-size=16g"
    ],
    // 自动配置 VS Code 插件
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-toolsai.jupyter"
            ]
        }
    },
    // 容器启动后自动检查环境
    "postCreateCommand": "python -c \"import torch; print(f'CUDA available: {torch.cuda.is_available()}'); print(f'Device: {torch.cuda.get_device_name(0)}')\""
}